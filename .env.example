# Copy to .env and adjust values.

# PostgreSQL connection string (required). Must include database name.
DATABASE_URL=postgresql://user:password@localhost:5432/automobilservice

# Optional: smoke script target when server runs elsewhere
# STABILIZATION_BASE_URL=http://127.0.0.1:3000

# Optional overrides (see config.js)
# PORT=3000
# NODE_ENV=development
# SESSION_SECRET=change-me-in-production
# PUBLIC_BASE_URL=https://automobilservice-okei.ru

# OpenRouter AI chat assistant
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
